        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(applescript)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:source.applescript
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(markdown|md)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:text.html.markdown
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(latex|tex)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:text.tex.latex
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(rst|restructuredtext)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:text.restructuredtext
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(regexp|regex)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:source.regexp
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})\s*([^`~\s]+)?(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      push:
        - meta_scope: markup.raw.block.fenced.code.carve
        - match: '^(`{3,}|~{3,})\s*$'
          captures:
            1: punctuation.definition.raw.end.carve
          pop: true

  # ----- Raw blocks (%%% FORMAT ... %%%) -----
  # A raw block is a fence whose info string starts with `=`: ```=html passes
  # its body through to that output format verbatim. It is NOT code, so no
  # language is embedded. Must be tried before `code-blocks`, which would
  # otherwise read `=html` as a language name.
  raw-blocks:
    - match: '^(`{3,}|~{3,})(=)([^\s`~]+)\s*$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: punctuation.definition.raw.format.carve
        3: entity.name.type.format.carve
      push:
        - meta_scope: markup.raw.block.carve
        - match: '^(`{3,}|~{3,})\s*$'
          captures:
            1: punctuation.definition.raw.end.carve
          pop: true

  # ----- Display math block ( ```math ... ``` ) -----
  math-blocks:
    - match: '^(`{3,}|~{3,})\s*(math)\s*$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.math.carve
      push:
        - meta_scope: markup.other.math.block.carve
        - meta_content_scope: markup.other.math.content.carve
        - match: '^(`{3,}|~{3,})\s*$'
          captures:
            1: punctuation.definition.raw.end.carve
          pop: true

  # ----- Divs (::: type "title" [label]) -----
  divs:
    - match: '^\s*(:::+)\s*([^\s{]+)?'
      captures:
        1: punctuation.definition.div.carve
        2: entity.name.type.div.carve
      push:
        - meta_scope: markup.other.div.carve
        - match: '"[^"]*"'
          scope: string.quoted.double.div-title.carve
        - match: '\[[^\]]*\]'
          scope: constant.other.reference.div-label.carve
        - match: '$'
          pop: true
        - include: highlight
        - include: forced-emphasis
        - include: attributes

  # ----- Tables -----
  tables:
    - match: '^(?=\s*\|)'
      push:
        - meta_scope: markup.table.row.carve
        - match: '\|='
          scope: keyword.operator.table.header.carve
        - match: '(?<=\|)\s*(\^)\s*(?=\|)'
          captures:
            1: keyword.operator.table.rowspan.carve
        - match: '(?<=\|)\s*(<)\s*(?=\|)'
          captures:
            1: keyword.operator.table.colspan.carve
        # Separator/alignment cell: the dash run is the delimiter; leading/
        # trailing alignment colons (`:--`, `--:`, `:-:`) get their own scope.
        - match: '(?<=\|)\s*(:?)(-+)(:?)\s*(?=\|)'
          captures:
            1: keyword.operator.table.alignment.carve
            2: punctuation.separator.table.delimiter.carve
            3: keyword.operator.table.alignment.carve
        - match: '\|'
          scope: punctuation.separator.table.carve
        - include: trailing-comment-cell
        - include: inline-literal
        - include: inline-code
        - include: extension-inline
        - include: critic-markup
        - include: emphasis
        - include: links
        - include: images
        - include: autolink
        - include: sup-sub
        - include: highlight
        - include: forced-emphasis
        - include: attributes
        - match: '$'
          pop: true
    - match: '^(\+)(.*)$'
      scope: markup.table.continuation.carve
      captures:
        1: keyword.operator.table.continuation.carve
    - include: captions

  # ----- Caption lines ( `^ text` under a table, image, quote, or code block ) -----
  # One rule for every caption: the construct is the same wherever it appears
  # (all render to <figcaption> / <caption>), so a table caption and an image
  # caption share a scope. `^[` (inline note) has no space and is not a caption.
  # The body is full inline markup, so `^ Figure 1: a /styled/ caption` works.
  captions:
    - match: '^\s*(\^)(?=\s)'
      captures:
        1: punctuation.definition.caption.carve
      push:
        - meta_scope: markup.caption.carve
        - match: '$'
          pop: true
        - include: inline

  # ----- Block quotes -----
  block-quotes:
    - match: '^\s*(>+)\s?'
      captures:
        1: punctuation.definition.quote.carve
      push:
        - meta_scope: markup.quote.carve
        - match: '$'
          pop: true
        - include: trailing-comment
        - include: inline

  # ----- Lists + tasks + definition lists -----
  lists:
    - match: '^(\s*)(\+)(\s*)$'
      captures:
        2: punctuation.definition.list.continuation.carve
      scope: markup.list.continuation.carve
    - match: '^(\s*)([-*])\s+(\[[ xX]\]\s+)?'
      scope: markup.list.unnumbered.carve
      captures:
        2: punctuation.definition.list.begin.carve
        3: constant.language.task-list.carve
    - match: '^(\s*)([0-9]+[.)]|[A-Za-z][.)]|[ivxlcdmIVXLCDM]+[.)])\s+'
      scope: markup.list.numbered.carve
      captures:
        2: punctuation.definition.list.begin.carve
    - match: '^(\s*)(::)\s+'
      scope: markup.list.definition.term.carve
      captures:
        2: punctuation.definition.list.begin.carve
    - match: '^(\s*)(:)\s+'
      scope: markup.list.definition.carve
      captures:
        2: punctuation.definition.list.begin.carve

  # ----- Reference + abbreviation definitions -----
  definitions:
    - match: '^\s*(\[[^\]]+\]:)\s+(\S+)'
      scope: meta.link.reference.definition.carve
      captures:
        1: constant.other.reference.link.carve
        2: markup.underline.link.carve
    - match: '^\s*(\*)(\[)([A-Z][A-Z0-9]*)(\])(:)\s+(.*)$'
      scope: meta.abbreviation.definition.carve
      captures:
        1: punctuation.definition.abbreviation.carve
        2: punctuation.definition.abbreviation.carve
        3: entity.name.abbreviation.carve
        4: punctuation.definition.abbreviation.carve
        5: punctuation.separator.carve
        6: string.unquoted.abbreviation.carve

  # ----- Links / references / spans -----
  links:
    - match: '(\[)([^\]]+)(\])(\()([^\s)]+)(?:\s+"([^"]+)")?(\))'
      scope: meta.link.inline.carve
      captures:
        1: punctuation.definition.link.begin.carve
        2: string.other.link.title.carve
        3: punctuation.definition.link.end.carve
        4: punctuation.definition.metadata.begin.carve
        5: markup.underline.link.carve
        6: string.quoted.double.link-title.carve
        7: punctuation.definition.metadata.end.carve
    - match: '(\[)([^\]]+)(\])(\[)([^\]]*)(\])'
      scope: meta.link.reference.carve
      captures:
        2: string.other.link.title.carve
        5: constant.other.reference.link.carve
    - match: '(\[)([^\^\]][^\]]*)(\])(?=\{)'
      scope: meta.span.inline.carve
      captures:
        1: punctuation.definition.span.begin.carve
        2: string.other.span.carve
        3: punctuation.definition.span.end.carve

  # ----- Images -----
  images:
    - match: '(!\[)([^\]]*)(\]\()([^\s)]+)(?:\s+"([^"]+)")?(\))'
      scope: meta.image.inline.carve
      captures:
        1: punctuation.definition.image.begin.carve
        2: string.other.image.alt.carve
        4: markup.underline.link.image.carve
        5: string.quoted.double.image-title.carve

  # ----- Cross-references ( </#id> ) -----
  # Carve's own construct: the link text is filled from the target heading.
  # Must be tried before `autolink`, whose `<scheme:...>` rule cannot match it.
  crossrefs:
    - match: '(</#)([^>\s]+)(>)'
      scope: meta.link.crossref.carve
      captures:
        1: punctuation.definition.crossref.begin.carve
        2: constant.other.reference.crossref.carve
        3: punctuation.definition.crossref.end.carve

  # ----- Footnotes -----
  footnotes:
    # Inline note `^[content]` (grammar section 16). The body is full inline
    # markup, so `^[a /styled/ note]` highlights inside the note.
    - match: '(\^\[)'
      captures:
        1: punctuation.definition.footnote.begin.carve
      push:
        - meta_scope: meta.footnote.inline.carve
        - match: '\]'
          scope: punctuation.definition.footnote.end.carve
          pop: true
        - include: inline
    - match: '(\[)(\^)([^\]]+)(\])'
      scope: constant.other.reference.footnote.carve
      captures:
        1: punctuation.definition.footnote.carve
        2: punctuation.definition.footnote.carve
        3: constant.other.footnote.carve
        4: punctuation.definition.footnote.carve

  highlight:
    - match: '(\{=)(?=\S)([^\n]*?)(=\})'
      scope: markup.highlight.carve
      captures:
        1: punctuation.definition.highlight.carve
        2: markup.highlight.carve
        3: punctuation.definition.highlight.carve
    - match: '(?<![\w=])(=)(?=\S)([^=\n]+?)(?<=\S)(=)(?![\w=])'
      scope: markup.highlight.carve
      captures:
        1: punctuation.definition.highlight.carve
        2: markup.highlight.carve
        3: punctuation.definition.highlight.carve

  forced-emphasis:
    - match: '(\{\*)(?=\S)([^\n]*?)(\*\})'
      scope: markup.bold.carve
      captures:
        1: punctuation.definition.bold.carve
        2: markup.bold.carve
        3: punctuation.definition.bold.carve
    - match: '(\{/)(?=\S)([^\n]*?)(/\})'
      scope: markup.italic.carve
      captures:
        1: punctuation.definition.italic.carve
        2: markup.italic.carve
        3: punctuation.definition.italic.carve
    - match: '(\{_)(?=\S)([^\n]*?)(_\})'
      scope: markup.underline.carve
      captures:
        1: punctuation.definition.underline.carve
        2: markup.underline.carve
        3: punctuation.definition.underline.carve
    - match: '(\{~)(?=\S)((?:(?!~>)[^\n])*?)(~\})'
      scope: markup.strikethrough.carve
      captures:
        1: punctuation.definition.strike.carve
        2: markup.strikethrough.carve
        3: punctuation.definition.strike.carve

  # ----- Block / inline attributes {...} -----
  attributes:
    - match: '\{'
      scope: punctuation.definition.attributes.begin.carve
      push:
        - meta_scope: meta.attributes.carve
        - match: '\}'
          scope: punctuation.definition.attributes.end.carve
          pop: true
        - match: '#[A-Za-z_][A-Za-z0-9_-]*'
          scope: entity.other.attribute-name.id.carve
        - match: '\.[A-Za-z_][A-Za-z0-9_-]*'
          scope: entity.other.attribute-name.class.carve
        - match: '[A-Za-z_:][A-Za-z0-9_:-]*(?==)'
          scope: entity.other.attribute-name.carve
        - match: '"[^"]*"'
          scope: string.quoted.double.attribute.carve
        - match: "'[^']*'"
          scope: string.quoted.single.attribute.carve

  # ----- Raw inline passthrough ( `code`{=format} ) -----
  raw-inline:
    - match: '(`+)([^`]|[^`][\s\S]*?[^`])(\1)(\{=)([A-Za-z_][\w-]*)(\})'
      scope: markup.raw.inline.passthrough.carve
      captures:
        1: punctuation.definition.raw.carve
        2: markup.raw.inline.content.carve
        3: punctuation.definition.raw.carve
        4: punctuation.definition.raw.format.begin.carve
        5: entity.name.type.format.carve
        6: punctuation.definition.raw.format.end.carve

  # ----- Inline code -----
  inline-code:
    - match: '(`+)([^`]|[^`][\s\S]*?[^`])(\1)'
      scope: markup.raw.inline.carve
      captures:
        1: punctuation.definition.raw.carve
        2: markup.raw.inline.content.carve
        3: punctuation.definition.raw.carve

  # ----- Inline literal ( !`..` ) -----
  # A `!` prefix on a verbatim backtick span renders as literal prose (no
  # <code>), mirroring the `$`-math prefix. Must precede inline-code so the
  # `!` is claimed with the span rather than left as stray text.
  # Single match with a backreferenced closer (\2), exactly as inline-code
  # does: a push/pop pair would pop on the first backtick run of ANY length,
  # ending `!``a ` b`` ` early on its inner backtick. Unlike math there is no
  # closing sentinel to anchor the end, so the run length has to be matched.
  inline-literal:
    - match: '(!)(`+)([^`]|[^`][\s\S]*?[^`])(\2)'
      scope: markup.raw.inline.literal.carve
      captures:
        1: punctuation.definition.literal.carve
        2: punctuation.definition.raw.carve
        3: markup.raw.inline.content.carve
        4: punctuation.definition.raw.carve

  # ----- Inline math ( $`..` and $$`..` ) -----
  math:
    - match: '(\$\$)(`+)'
      captures:
        1: punctuation.definition.math.carve
        2: punctuation.definition.raw.carve
      push:
        - meta_scope: markup.other.math.display.carve
        - meta_content_scope: markup.other.math.content.carve
        - match: '(`+)'
          scope: punctuation.definition.raw.carve
          pop: true
    - match: '(\$)(`+)'
      captures:
        1: punctuation.definition.math.carve
        2: punctuation.definition.raw.carve
      push:
        - meta_scope: markup.other.math.inline.carve
        - meta_content_scope: markup.other.math.content.carve
        - match: '(`+)'
          scope: punctuation.definition.raw.carve
          pop: true

  # ----- Autolinks -----
  autolink:
    - match: '(<)([a-zA-Z][a-zA-Z0-9+.\-]*:[^>\s]+)(>)'
      scope: meta.link.autolink.carve
      captures:
        1: punctuation.definition.link.carve
        2: markup.underline.link.carve
        3: punctuation.definition.link.carve
    - match: '(<)([A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,})(>)'
      scope: meta.link.autolink.email.carve
      captures:
        1: punctuation.definition.link.carve
        2: markup.underline.link.carve
        3: punctuation.definition.link.carve

  # ----- Inline extensions ( :name[content]{attrs} ) -----
  extension-inline:
    - match: '(:)([a-zA-Z][\w-]*)(\[)([^\]]*)(\])(\{[^}]*\})?'
      scope: meta.extension.inline.carve
      captures:
        1: punctuation.definition.extension.carve
        2: entity.name.function.extension.carve
        3: punctuation.definition.extension.carve
        4: string.unquoted.extension.carve
        5: punctuation.definition.extension.carve
        6: meta.attributes.carve

  # ----- Critic markup -----
  critic-markup:
    - match: '(\{\+)([^}]*)(\+\})'
      scope: markup.inserted.critic.carve
      captures:
        1: punctuation.definition.critic.carve
        2: markup.inserted.carve
        3: punctuation.definition.critic.carve
    - match: '(\{-)([^}]*)(- \}|\-\})'
      scope: markup.deleted.critic.carve
      captures:
        1: punctuation.definition.critic.carve
        2: markup.deleted.carve
        3: punctuation.definition.critic.carve
    - match: '(\{~)([^~]*)(~>)([^~]*)(~\})'
      scope: markup.changed.critic.carve
      captures:
        1: punctuation.definition.critic.carve
        2: markup.deleted.carve
        3: punctuation.definition.critic.carve
        4: markup.inserted.carve
        5: punctuation.definition.critic.carve
    - match: '(\{#)([^}]*)(#\})'
      scope: comment.block.critic.carve
      captures:
        1: punctuation.definition.critic.carve
        2: comment.block.content.carve
        3: punctuation.definition.critic.carve

  # ----- Emphasis / inline mnemonics -----
  emphasis:
    - match: '(/\*)(?=\S)([^*]+)(\*/)'
      scope: markup.bold.italic.carve
      captures:
        1: punctuation.definition.bold-italic.carve
        2: markup.bold.italic.carve
        3: punctuation.definition.bold-italic.carve
    - match: '(\*)(?=\S)([^*\n]+?)(?<=\S)(\*)'
      scope: markup.bold.carve
      captures:
        1: punctuation.definition.bold.carve
        2: markup.bold.carve
        3: punctuation.definition.bold.carve
    - match: '(?<![\w/])(/)(?=\S)([^/\n]+?)(?<=\S)(/)(?![\w/])'
      scope: markup.italic.carve
      captures:
        1: punctuation.definition.italic.carve
        2: markup.italic.carve
        3: punctuation.definition.italic.carve
    - match: '(?<![\w_])(_)(?=\S)([^_\n]+?)(?<=\S)(_)(?![\w_])'
      scope: markup.underline.text.carve
      captures:
        1: punctuation.definition.underline.carve
        2: markup.underline.text.carve
        3: punctuation.definition.underline.carve
    - match: '(~)(?=\S)([^~\n]+?)(?<=\S)(~)'
      scope: markup.strikethrough.carve
      captures:
        1: punctuation.definition.strike.carve
        2: markup.strikethrough.carve
        3: punctuation.definition.strike.carve
    - match: '(==)([^=\n]+?)(==)'
      scope: markup.highlight.carve
      captures:
        1: punctuation.definition.highlight.carve
        2: markup.highlight.carve
        3: punctuation.definition.highlight.carve

  # ----- Superscript / subscript (braced forms only: {^sup^} / {,sub,}) -----
  # Bare ^sup^ / ,sub, no longer exist in Carve; a lone ^ or , is literal text.
  sup-sub:
    - match: '(\{\^)(?=\S)([^^\n]+?)(\^\})'
      scope: markup.superscript.carve
      captures:
        1: punctuation.definition.superscript.carve
        2: markup.superscript.carve
        3: punctuation.definition.superscript.carve
    - match: '(\{,)(?=\S)([^,\n]+?)(,\})'
      scope: markup.subscript.carve
      captures:
        1: punctuation.definition.subscript.carve
        2: markup.subscript.carve
        3: punctuation.definition.subscript.carve

  # ----- Citations: [@key, loc; -@key2] with no (url)/[ref]/{attr} tail -----
  #
  # A citation group is a bracket whose first non-whitespace content after an
  # optional '+' is or contains an '@key'. The whole bracket has no tail.
  # Key charset: [A-Za-z0-9_][A-Za-z0-9_:.#$%&+?<>~/-]*
  citations:
    - match: '(\[\+?)(?=[^\]]*@[A-Za-z0-9_][A-Za-z0-9_:.#$%&+?<>\~\/\-]*)([^\]]*?)(@[A-Za-z0-9_][A-Za-z0-9_:.#$%&+?<>\~\/\-]*)([^\]]*)(\])(?![\(\[\{])'
      scope: meta.citation.carve
      captures:
        1: punctuation.definition.citation.begin.carve
        2: string.other.citation.prefix.carve
        3: constant.other.symbol.mention.carve
        4: string.other.citation.locator.carve
        5: punctuation.definition.citation.end.carve

  # ----- CodeCallout markers: <N> (digits only) -----
  code-callouts:
    - match: '<(\d+)>'
      scope: meta.code-callout.carve
      captures:
        0: constant.numeric.callout.carve

  # ----- Mentions / tags / emoji -----
  mentions-tags:
    - match: '(?<![\w.])(@)([A-Za-z0-9_][A-Za-z0-9_-]*)'
      scope: constant.other.symbol.mention.carve
      captures:
        1: punctuation.definition.mention.carve
        2: variable.other.mention.carve
    - match: '(?<!\w)(#)([A-Za-z0-9_][A-Za-z0-9_-]*)'
      scope: constant.other.symbol.tag.carve
      captures:
        1: punctuation.definition.tag.carve
        2: variable.other.tag.carve
    - match: ':[A-Za-z0-9_+-]+:'
      scope: constant.character.emoji.carve

  # ----- Smart typography / escapes -----
  smart-typography:
    - match: '\\[\\`*_{}\[\]()#+\-.!~^/<>@%|=,]'
      scope: constant.character.escape.carve
    - match: '\.\.\.|---|--|<->|<-|->|=>|!=|<=|>=|\+-|\(c\)|\(r\)|\(tm\)'
      scope: constant.character.typography.carve
    - match: '"'
      scope: punctuation.definition.smartquote.carve
