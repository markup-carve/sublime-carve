%YAML 1.2
---
# Carve syntax for Sublime Text 3/4.
# Authored from the maintained TextMate grammar (scope text.carve):
#   vscode-carve/syntaxes/carve.tmLanguage.json
# Scope names mirror that grammar so existing color schemes light it up.
#
# The syntax_test_carve.crv assertions run in CI (SublimeText/syntax-test-action)
# and locally without a GUI: download the headless runner for your build from
#   https://download.sublimetext.com/st_syntax_tests_build_<BUILD>_x64.tar.xz
# then copy this package into its Data/Packages/Carve and run ./syntax_tests.
name: Carve
file_extensions:
  - crv
scope: text.carve

variables:
  ws: '[ \t]'

contexts:
  main:
    - include: frontmatter
    - include: comments
    - include: headings
    - include: raw-blocks
    - include: code-blocks
    - include: math-blocks
    - include: divs
    - include: tables
    - include: block-quotes
    - include: captions
    - include: lists
    - include: definitions
    - include: citations
    - include: crossrefs
    - include: links
    - include: images
    - include: footnotes
    - include: critic-markup
    - include: sup-sub
    - include: highlight
    - include: forced-emphasis
    - include: attributes
    - include: raw-inline
    - include: inline-literal
    - include: inline-code
    - include: trailing-comment
    - include: math
    - include: autolink
    - include: extension-inline
    - include: emphasis
    - include: mentions-tags
    - include: code-callouts
    - include: smart-typography

  # ----- inline-only group (reused inside tables, etc.) -----
  inline:
    - include: raw-inline
    - include: inline-literal
    - include: inline-code
    - include: math
    - include: crossrefs
    - include: autolink
    - include: extension-inline
    - include: critic-markup
    - include: citations
    - include: links
    - include: images
    - include: footnotes
    - include: sup-sub
    - include: highlight
    - include: forced-emphasis
    - include: attributes
    - include: emphasis
    - include: mentions-tags
    - include: code-callouts
    - include: smart-typography

  # ----- Frontmatter -----
  # Carve does not interpret frontmatter - the fence token declares the format
  # and the application parses it - so highlight the body with that format's
  # syntax. Bare `---` is YAML by convention; `---toml` / `---json` embed those.
  frontmatter:
    - match: '\A(---)[ \t]*(toml)[ \t]*$'
      captures:
        1: punctuation.definition.frontmatter.begin.carve
        2: entity.name.type.frontmatter.carve
      embed: scope:source.toml
      embed_scope: meta.frontmatter.carve
      escape: '^(---)\s*$'
      escape_captures:
        1: punctuation.definition.frontmatter.end.carve
    - match: '\A(---)[ \t]*(json)[ \t]*$'
      captures:
        1: punctuation.definition.frontmatter.begin.carve
        2: entity.name.type.frontmatter.carve
      embed: scope:source.json
      embed_scope: meta.frontmatter.carve
      escape: '^(---)\s*$'
      escape_captures:
        1: punctuation.definition.frontmatter.end.carve
    - match: '\A(---)[ \t]*(yaml|yml)?[ \t]*$'
      captures:
        1: punctuation.definition.frontmatter.begin.carve
        2: entity.name.type.frontmatter.carve
      embed: scope:source.yaml
      embed_scope: meta.frontmatter.carve
      escape: '^(---)\s*$'
      escape_captures:
        1: punctuation.definition.frontmatter.end.carve
    # An unknown format keeps the body as plain text.
    - match: '\A(---)[ \t]*([A-Za-z0-9_-]+)[ \t]*$'
      captures:
        1: punctuation.definition.frontmatter.begin.carve
        2: entity.name.type.frontmatter.carve
      push:
        - meta_scope: meta.frontmatter.carve
        - match: '^(---)\s*$'
          captures:
            1: punctuation.definition.frontmatter.end.carve
          pop: true
        - match: '.+'
          scope: string.unquoted.frontmatter.carve

  # ----- Comments -----
  comments:
    # A block comment fence is three OR MORE percent signs (fmt widens the
    # fence when the body contains a `%%%` run), so match `%{3,}`.
    - match: '^\s*(%{3,})\s*$'
      captures:
        1: punctuation.definition.comment.carve
      push:
        - meta_scope: comment.block.carve
        - match: '^\s*(%{3,})\s*$'
          captures:
            1: punctuation.definition.comment.carve
          pop: true
    - match: '^\s*%%(?!%).*$'
      scope: comment.line.percent.carve

  trailing-comment:
    - match: '(?<=[ \t])%%.*$'
      scope: comment.line.percent.carve

  trailing-comment-cell:
    - match: '(?<=[ \t])%%[^|]*'
      scope: comment.line.percent.carve

  # ----- Headings -----
  headings:
    - match: '^(#{1,6})(\s+)(.+)$'
      scope: markup.heading.carve
      captures:
        1: punctuation.definition.heading.carve
        3: entity.name.section.carve

  # ----- Fenced code blocks (with optional language + #201 "header"/[label]) -----
  # Fenced code. A block whose info string names a language Sublime ships gets
  # that language embedded, so the code inside is really highlighted; anything
  # else (mermaid, chart, an unknown tag, no tag at all) falls through to the
  # last rule and stays plain raw text.
  code-blocks:
    - match: '^(`{3,}|~{3,})[ \t]*(python|py)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
        2: entity.name.type.language.carve
        3: meta.code-fence.header.carve
      embed: scope:source.python
      embed_scope: markup.raw.block.fenced.code.carve
      escape: '^(`{3,}|~{3,})\s*$'
      escape_captures:
        1: punctuation.definition.raw.end.carve
    - match: '^(`{3,}|~{3,})[ \t]*(javascript|js|node)\b(.*)$'
      captures:
        1: punctuation.definition.raw.begin.carve
