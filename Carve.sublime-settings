{
    // Carve is prose-oriented markup; soft tabs keep nesting predictable.
    "tab_size": 2,
    "translate_tabs_to_spaces": true,
    "trim_trailing_white_space_on_save": false,
    "word_wrap": true,
    "wrap_width": 0,
    "draw_centered": false,
    "spell_check": true,
    "auto_complete_triggers":
    [
        { "selector": "text.carve", "characters": "[" },
        { "selector": "text.carve", "characters": ":" }
    ]
}
